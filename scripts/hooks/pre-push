#!/usr/bin/env bash
set -e

# Pre-push hook: thorough checks with SHA-based caching.
# Skips test run when HEAD matches .test-passed from a previous successful run.

HEAD_SHA=$(git rev-parse HEAD 2>/dev/null)
CACHED_SHA=""
if [ -f .test-passed ]; then
  CACHED_SHA=$(cat .test-passed 2>/dev/null | tr -d '[:space:]')
fi

if [ -n "$HEAD_SHA" ] && [ "$HEAD_SHA" = "$CACHED_SHA" ]; then
  echo "Tests already passed for $HEAD_SHA - skipping."
else
  echo "Running typecheck + test suite before push..."
  npm run typecheck
  npm run test:run
  echo "$HEAD_SHA" > .test-passed
fi

echo "Checking dependencies..."
npm audit --audit-level=moderate || echo "  (npm audit warnings - review when convenient)"
