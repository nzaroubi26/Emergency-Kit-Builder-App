{
  "permissions": {
    "allow": [
      "npm test",
      "npm run test:*",
      "npm run lint",
      "npm run build",
      "npm run dev",
      "npm start",
      "node scripts/*",
      "npx jest*",
      "npx eslint*",
      "npx prettier*",
      "git status",
      "git diff*",
      "git log*",
      "git branch*",
      "git add*",
      "git commit*",
      "git stash*",
      "git checkout*",
      "git switch*",
      "git merge*",
      "git rebase*",
      "ls*",
      "cat*",
      "head*",
      "tail*",
      "wc*",
      "find*",
      "grep*",
      "which*",
      "echo*",
      "mkdir*"
    ],
    "deny": [
      "rm -rf /",
      "rm -rf ~",
      "rm -rf /*",
      "rm -rf ~/*",
      "rm -rf .",
      "rm -rf ..",
      "git push --force",
      "git push -f",
      "git push origin --force",
      "git push origin -f",
      "git reset --hard",
      "git clean -fd",
      "git clean -fdx",
      "git checkout -- .",
      "chmod -R 777*",
      "curl * | sh",
      "curl * | bash",
      "wget * | sh",
      "wget * | bash",
      "npm publish",
      "> /dev/sda*",
      "dd if=*",
      "mkfs*",
      ":(){ :|:& };:"
    ]
  }
}
